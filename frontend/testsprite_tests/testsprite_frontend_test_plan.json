  {
    "id": "TC001",
    "title": "Search leads with a valid query shows candidate results",
    "description": "Verifies that entering a valid job-title query returns a visible list of candidate results on the dashboard.",
    "category": "Search Leads",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "action",
        "description": "Click on the search input in the command palette"
      },
      {
        "type": "action",
        "description": "Type \"Software Engineer\" into the search input"
      },
      {
        "type": "assertion",
        "description": "Verify element \"candidate results list\" is visible"
      }
    ]
  },
